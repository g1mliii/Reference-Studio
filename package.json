{
  "name": "reference-studio",
  "version": "0.1.0",
  "description": "macOS desktop app for Gemini-powered reference-based image generation workflows.",
  "author": "Subaigsuri",
  "type": "module",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac dmg zip --arm64",
    "dist:github": "electron-builder --mac dmg zip --arm64 --publish never -c.publish.provider=github -c.publish.owner=$UPDATE_REPO_OWNER -c.publish.repo=$UPDATE_REPO_NAME",
    "release:github": "electron-builder --mac dmg zip --arm64 --publish always -c.publish.provider=github -c.publish.owner=$UPDATE_REPO_OWNER -c.publish.repo=$UPDATE_REPO_NAME"
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "electron-log": "^5.4.1",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.subaigsuri.referencestudio",
    "productName": "Reference Studio",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
